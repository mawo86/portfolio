---
const navLinks = [
  { href: '/#ueber-mich', label: 'Über mich' },
  { href: '/#leistungen', label: 'Leistungen' },
  { href: '/#projekte', label: 'Projekte' },
  { href: '/#referenzen', label: 'Referenzen' },
  { href: '/blog', label: 'Blog' },
  { href: '/#kontakt', label: 'Kontakt' },
];

const currentPath = Astro.url.pathname;
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="absolute inset-0 bg-[#080B14]/0 backdrop-blur-0 transition-all duration-300" id="header-bg"></div>
  <nav class="relative max-w-6xl mx-auto px-6 py-5 flex items-center justify-between">
    <!-- Logo -->
    <a href={import.meta.env.BASE_URL} class="flex items-center gap-2.5 group" aria-label="Busche Cloud">
      <svg width="32" height="28" viewBox="0 0 32 28" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="cloudGradH" x1="0" y1="0" x2="32" y2="28" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#38BDF8"/>
            <stop offset="100%" stop-color="#0080CC"/>
          </linearGradient>
        </defs>
        <!-- Cloud shape -->
        <path d="M25 18H8C5.2 18 3 15.8 3 13C3 10.5 4.8 8.4 7.2 8.1C7.1 7.7 7 7.4 7 7C7 4.8 8.8 3 11 3C12.1 3 13.1 3.4 13.8 4.2C14.7 2.9 16.2 2 18 2C20.8 2 23 4.2 23 7C23 7.1 23 7.2 23 7.3C24.7 7.8 26 9.3 26 11C26 11.1 26 11.2 26 11.3C27.2 11.9 28 13.1 28 14.5C28 16.4 26.7 18 25 18Z" fill="url(#cloudGradH)"/>
        <!-- B letter -->
        <text x="10" y="16" font-family="Arial Black, sans-serif" font-weight="900" font-size="10" fill="white">B</text>
      </svg>
      <div class="flex items-baseline gap-1">
        <span class="text-xl font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#38BDF8] to-[#0095E8]">BUSCHE</span>
        <span class="text-xs font-bold tracking-widest text-[#0095E8] uppercase">Cloud</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="text-sm text-gray-400 hover:text-white transition-colors font-medium relative group"
          >
            {link.label}
            <span class="absolute -bottom-0.5 left-0 w-0 h-px bg-brand-400 transition-all duration-300 group-hover:w-full"></span>
          </a>
        </li>
      ))}
    </ul>

    <!-- CTA -->
    <a
      href="/#kontakt"
      class="hidden md:inline-flex items-center gap-2 px-4 py-2 text-sm font-medium bg-brand-500/10 hover:bg-brand-500/20 text-brand-300 border border-brand-500/30 hover:border-brand-400/50 rounded-lg transition-all"
    >
      Jetzt anfragen
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </a>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="md:hidden p-2 text-gray-400 hover:text-white transition-colors" aria-label="Menü öffnen">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/10 bg-[#080B14]/95 backdrop-blur-xl">
    <ul class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
      {navLinks.map(link => (
        <li>
          <a href={link.href} class="block py-2.5 px-3 text-gray-300 hover:text-white hover:bg-white/5 rounded-lg transition-colors text-sm font-medium">
            {link.label}
          </a>
        </li>
      ))}
      <li class="mt-2 pt-2 border-t border-white/10">
        <a href="/#kontakt" class="block py-2.5 px-3 text-center bg-brand-500 hover:bg-brand-400 text-white rounded-lg text-sm font-medium transition-colors">
          Jetzt anfragen
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Header scroll effect
  const header = document.getElementById('header');
  const headerBg = document.getElementById('header-bg');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      headerBg?.classList.add('!bg-[#080B14]/90', '!backdrop-blur-xl');
      header?.classList.add('border-b', 'border-white/5');
    } else {
      headerBg?.classList.remove('!bg-[#080B14]/90', '!backdrop-blur-xl');
      header?.classList.remove('border-b', 'border-white/5');
    }
  });

  // Mobile menu
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close mobile menu on link click
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
