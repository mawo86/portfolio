---
export interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
const action = 'https://buttondown.com/api/emails/embed-subscribe/buschecloud';

// Eindeutige ID, damit mehrere Instanzen auf einer Seite nebeneinander funktionieren
const id = 'nl-' + Math.random().toString(36).slice(2, 9);
---

{compact ? (
  <div class="p-6 border border-white/10 rounded-xl bg-white/2" data-newsletter-root={id}>
    <p class="text-xs font-bold uppercase tracking-widest text-brand-400 mb-2">Newsletter</p>
    <p class="text-white font-semibold text-sm mb-4">Neue Artikel direkt ins Postfach — kein Spam, jederzeit abmeldbar.</p>
    <form
      action={action}
      method="post"
      class="flex flex-col sm:flex-row gap-3"
      data-newsletter-form
    >
      <label for={`${id}-email`} class="sr-only">E-Mail-Adresse</label>
      <input
        id={`${id}-email`}
        type="email"
        name="email"
        placeholder="Deine E-Mail-Adresse"
        required
        autocomplete="email"
        class="flex-1 px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-brand-500/50 transition-colors"
      />
      <button
        type="submit"
        class="px-5 py-2.5 bg-brand-500 hover:bg-brand-400 text-white font-semibold rounded-lg transition-colors text-sm whitespace-nowrap disabled:opacity-50"
      >
        Abonnieren
      </button>
    </form>
    <p data-newsletter-status class="sr-only" role="status" aria-live="polite"></p>
    <p class="text-xs text-gray-600 mt-3">
      Mit der Anmeldung stimmst du zu, E-Mails zu erhalten. Abmeldung jederzeit per Klick.
      <a href="/datenschutz#newsletter" class="text-gray-500 hover:text-gray-400 transition-colors">Datenschutz</a>
    </p>
  </div>
) : (
  <div class="p-8 border border-white/10 rounded-xl bg-white/2" data-newsletter-root={id}>
    <div class="flex flex-col sm:flex-row sm:items-start gap-6">
      <div class="flex-1">
        <p class="text-xs font-bold uppercase tracking-widest text-brand-400 mb-3">Newsletter</p>
        <h3 class="text-xl font-black text-white mb-2 leading-tight">Bleib auf dem Laufenden.</h3>
        <p class="text-gray-400 text-sm leading-relaxed mb-5">
          Neue Artikel zu KI-Automatisierung und digitaler Transformation — direkt ins Postfach. Kein Spam, kein Tracking, jederzeit abmeldbar.
        </p>
        <form
          action={action}
          method="post"
          class="flex flex-col sm:flex-row gap-3"
          data-newsletter-form
        >
          <label for={`${id}-email`} class="sr-only">E-Mail-Adresse</label>
          <input
            id={`${id}-email`}
            type="email"
            name="email"
            placeholder="Deine E-Mail-Adresse"
            required
            autocomplete="email"
            class="flex-1 px-4 py-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white placeholder:text-gray-500 focus:outline-none focus:border-brand-500/50 transition-colors"
          />
          <button
            type="submit"
            class="px-5 py-2.5 bg-brand-500 hover:bg-brand-400 text-white font-semibold rounded-lg transition-colors text-sm whitespace-nowrap disabled:opacity-50"
          >
            Abonnieren
          </button>
        </form>
        <p data-newsletter-status class="sr-only" role="status" aria-live="polite"></p>
        <p class="text-xs text-gray-600 mt-3">
          Mit der Anmeldung stimmst du zu, E-Mails zu erhalten. Abmeldung jederzeit per Klick.
          <a href="/datenschutz#newsletter" class="text-gray-500 hover:text-gray-400 transition-colors">Datenschutz</a>
        </p>
      </div>
    </div>
  </div>
)}

<script>
  // Newsletter-Submit ohne Popup-Window. Buttondown akzeptiert auch
  // ein normales form-POST und gibt eine HTML-Bestätigungsseite zurück — wir
  // submitten via fetch und zeigen eine Inline-Bestätigung.
  document.querySelectorAll<HTMLFormElement>('form[data-newsletter-form]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const root = form.closest('[data-newsletter-root]');
      const status = root?.querySelector<HTMLElement>('[data-newsletter-status]');
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const input = form.querySelector<HTMLInputElement>('input[type="email"]');
      if (!status || !btn || !input) return;

      btn.disabled = true;
      btn.textContent = 'Wird gesendet…';

      try {
        const fd = new FormData(form);
        await fetch(form.action, {
          method: 'POST',
          body: fd,
          mode: 'no-cors', // Buttondown unterstützt kein CORS — Antwort opaque, aber Request kommt durch
        });

        // Form ausblenden, Erfolg zeigen
        form.style.display = 'none';
        status.classList.remove('sr-only');
        status.className = 'mt-2 p-4 rounded-lg bg-brand-500/10 border border-brand-500/20 text-brand-300 text-sm';
        status.innerHTML = '<strong>Fast geschafft.</strong> Bitte bestätige die Anmeldung in der E-Mail, die wir dir gerade gesendet haben.';
      } catch {
        btn.disabled = false;
        btn.textContent = 'Abonnieren';
        status.classList.remove('sr-only');
        status.className = 'mt-2 p-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-300 text-sm';
        status.textContent = 'Da ging etwas schief. Versuch es bitte gleich nochmal.';
      }
    });
  });
</script>
