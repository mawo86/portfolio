---
// Testimonials — Sozial-Proof.
// Sobald echte Zitate vorhanden sind, hier ergänzen. Solange die Liste leer
// ist, rendert die Komponente nichts.
type Testimonial = {
  quote: string;
  name: string;
  role: string;
  source?: 'LinkedIn' | 'Projekt' | 'Workshop';
};

const testimonials: Testimonial[] = [
  // {
  //   quote: 'Marlon hat unseren Prozess von 4 Tagen auf 2 Stunden gedrückt.',
  //   name: 'Vorname Nachname',
  //   role: 'Geschäftsführer · Firma',
  //   source: 'LinkedIn',
  // },
];
---

{testimonials.length > 0 && (
  <section id="stimmen" class="py-28 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-4">Stimmen</p>
        <h2 class="text-4xl font-bold text-white mb-4">Was andere sagen</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Aus echten Projekten und Empfehlungen — keine generischen Floskeln.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <figure class="relative bg-white/3 border border-white/8 rounded-2xl p-7 flex flex-col">
            <svg class="absolute top-5 right-5 w-7 h-7 text-brand-500/20" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
            </svg>
            <blockquote class="text-gray-200 text-base leading-relaxed mb-5 flex-1">
              {t.quote}
            </blockquote>
            <figcaption class="flex items-center gap-3 pt-5 border-t border-white/10">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-400 to-blue-600 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
                {t.name.split(' ').map(p => p[0]).join('').slice(0,2)}
              </div>
              <div>
                <div class="text-white text-sm font-semibold">{t.name}</div>
                <div class="text-gray-500 text-xs">{t.role}</div>
              </div>
              {t.source && (
                <span class="ml-auto text-[10px] font-bold uppercase tracking-wider text-gray-500 bg-white/5 border border-white/10 px-2 py-1 rounded-full">
                  {t.source}
                </span>
              )}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
)}
