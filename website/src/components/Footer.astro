---
const year = new Date().getFullYear();
const BASE = import.meta.env.BASE_URL;
---

<footer class="border-t border-white/5 bg-[#080B14]">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <!-- Brand -->
      <div>
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 mb-3" aria-label="Busche Cloud">
          <svg width="34" height="34" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="38" height="38" rx="9" fill="url(#iconBgF)"/>
            <defs>
              <linearGradient id="iconBgF" x1="0" y1="0" x2="38" y2="38" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#38BDF8"/>
                <stop offset="100%" stop-color="#0072B1"/>
              </linearGradient>
            </defs>
            <ellipse cx="24" cy="22" rx="8" ry="6" fill="white" fill-opacity="0.35"/>
            <path d="M8 26 C8 22 11 19 15 19 C15.5 17 17.5 15 20 15 C22.5 15 24.5 17 25 19 C27 19.5 28.5 21 28.5 23 C28.5 25.5 26.5 27 24 27 H11 C9.3 27 8 26 8 24 Z" fill="white"/>
            <text x="14.5" y="25.5" font-family="Arial Black, sans-serif" font-weight="900" font-size="10" fill="url(#iconBgF)">B</text>
          </svg>
          <div class="flex items-baseline gap-1">
            <span class="text-lg font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#38BDF8] to-[#0095E8]">BUSCHE</span>
            <span class="text-xs font-bold tracking-widest text-[#0095E8] uppercase">Cloud</span>
          </div>
        </a>
        <p class="text-gray-500 text-sm max-w-xs">KI-Automatisierung & Digitale Transformation für moderne Unternehmen.</p>
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row gap-8">
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Navigation</p>
          <ul class="flex flex-col gap-2">
            <li><a href={`${BASE}#ueber-mich`} class="text-sm text-gray-400 hover:text-white transition-colors">Über mich</a></li>
            <li><a href={`${BASE}#leistungen`} class="text-sm text-gray-400 hover:text-white transition-colors">Leistungen</a></li>
            <li><a href={`${BASE}#projekte`} class="text-sm text-gray-400 hover:text-white transition-colors">Projekte</a></li>
            <li><a href={`${BASE}blog`} class="text-sm text-gray-400 hover:text-white transition-colors">Blog</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Kontakt</p>
          <ul class="flex flex-col gap-2">
            <li><a href={`${BASE}#kontakt`} class="text-sm text-gray-400 hover:text-white transition-colors">Anfrage stellen</a></li>
            <li><a href="https://linkedin.com/in/marlon-b-26203116a" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-white transition-colors">LinkedIn</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600">© {year} Busche Cloud · Marlon Busche · OWL</p>
      <div class="flex gap-4">
        <a href={`${BASE}impressum`} class="text-xs text-gray-600 hover:text-gray-400 transition-colors">Impressum</a>
        <a href={`${BASE}datenschutz`} class="text-xs text-gray-600 hover:text-gray-400 transition-colors">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>
