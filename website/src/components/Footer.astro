---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-[#080B14]">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <!-- Brand -->
      <div>
        <a href={import.meta.env.BASE_URL} class="flex items-center gap-2 mb-3" aria-label="Busche Cloud">
          <svg width="28" height="24" viewBox="0 0 32 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="cloudGradF" x1="0" y1="0" x2="32" y2="28" gradientUnits="userSpaceOnUse">
                <stop offset="0%" stop-color="#38BDF8"/>
                <stop offset="100%" stop-color="#0080CC"/>
              </linearGradient>
            </defs>
            <path d="M25 18H8C5.2 18 3 15.8 3 13C3 10.5 4.8 8.4 7.2 8.1C7.1 7.7 7 7.4 7 7C7 4.8 8.8 3 11 3C12.1 3 13.1 3.4 13.8 4.2C14.7 2.9 16.2 2 18 2C20.8 2 23 4.2 23 7C23 7.1 23 7.2 23 7.3C24.7 7.8 26 9.3 26 11C26 11.1 26 11.2 26 11.3C27.2 11.9 28 13.1 28 14.5C28 16.4 26.7 18 25 18Z" fill="url(#cloudGradF)"/>
            <text x="10" y="16" font-family="Arial Black, sans-serif" font-weight="900" font-size="10" fill="white">B</text>
          </svg>
          <div class="flex items-baseline gap-1">
            <span class="text-lg font-black tracking-tight text-transparent bg-clip-text bg-gradient-to-r from-[#38BDF8] to-[#0095E8]">BUSCHE</span>
            <span class="text-xs font-bold tracking-widest text-[#0095E8] uppercase">Cloud</span>
          </div>
        </a>
        <p class="text-gray-500 text-sm max-w-xs">KI-Automatisierung & Digitale Transformation für moderne Unternehmen.</p>
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row gap-8">
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Navigation</p>
          <ul class="flex flex-col gap-2">
            <li><a href="/#ueber-mich" class="text-sm text-gray-400 hover:text-white transition-colors">Über mich</a></li>
            <li><a href="/#leistungen" class="text-sm text-gray-400 hover:text-white transition-colors">Leistungen</a></li>
            <li><a href="/#projekte" class="text-sm text-gray-400 hover:text-white transition-colors">Projekte</a></li>
            <li><a href="/blog" class="text-sm text-gray-400 hover:text-white transition-colors">Blog</a></li>
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-3">Kontakt</p>
          <ul class="flex flex-col gap-2">
            <li><a href="/#kontakt" class="text-sm text-gray-400 hover:text-white transition-colors">Anfrage stellen</a></li>
            <li><a href="https://linkedin.com/in/marlon-b-26203116a" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 hover:text-white transition-colors">LinkedIn</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-gray-600">© {year} Busche Cloud · Marlon Busche · OWL</p>
      <div class="flex gap-4">
        <a href="/impressum" class="text-xs text-gray-600 hover:text-gray-400 transition-colors">Impressum</a>
        <a href="/datenschutz" class="text-xs text-gray-600 hover:text-gray-400 transition-colors">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>
