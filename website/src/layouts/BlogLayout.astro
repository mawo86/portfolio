---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, description, date, tags } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<Layout title={`${title} — Busche Cloud`} description={description}>
  <Header />
  <main class="pt-32 pb-24">
    <article class="max-w-2xl mx-auto px-6">
      <!-- Back link -->
      <a href="/blog" class="inline-flex items-center gap-2 text-brand-400 hover:text-brand-300 text-sm mb-10 transition-colors group">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Zurück zum Blog
      </a>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-6">
        {tags.map(tag => (
          <span class="px-3 py-1 text-xs font-medium bg-brand-500/10 text-brand-400 border border-brand-500/20 rounded-full">
            {tag}
          </span>
        ))}
      </div>

      <!-- Title -->
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">{title}</h1>

      <!-- Date -->
      <p class="text-gray-500 text-sm mb-10 font-mono">{formattedDate}</p>

      <!-- Divider -->
      <div class="h-px bg-gradient-to-r from-brand-500/50 to-transparent mb-10"></div>

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none
        prose-headings:text-white prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-p:text-gray-300 prose-p:leading-relaxed
        prose-strong:text-white prose-strong:font-semibold
        prose-a:text-brand-400 prose-a:no-underline hover:prose-a:text-brand-300
        prose-li:text-gray-300
        prose-code:text-brand-300 prose-code:bg-white/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-sm
        prose-blockquote:border-l-brand-500 prose-blockquote:text-gray-400">
        <slot />
      </div>

      <!-- CTA -->
      <div class="mt-16 p-8 rounded-2xl bg-gradient-to-br from-brand-500/10 to-blue-600/5 border border-brand-500/20">
        <h3 class="text-xl font-bold text-white mb-2">Interesse geweckt?</h3>
        <p class="text-gray-400 mb-4">Lass uns besprechen, wie KI-Automatisierung auch deinem Unternehmen helfen kann.</p>
        <a href="/#kontakt" class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-500 hover:bg-brand-400 text-white font-medium rounded-lg transition-colors text-sm">
          Gespräch vereinbaren
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
