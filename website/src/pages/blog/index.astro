---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<Layout
  title="Blog — Busche Cloud"
  description="Gedanken, Insights und praktische Tipps zu KI-Automatisierung und digitaler Transformation von Marlon Busche."
>
  <Header />

  <main class="pt-32 pb-24">
    <div class="max-w-6xl mx-auto px-6">
      <!-- Header -->
      <div class="mb-16">
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-4">Blog</p>
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Gedanken & Insights</h1>
        <p class="text-gray-400 max-w-xl leading-relaxed">
          Meine Perspektiven zu KI, Automatisierung und digitaler Transformation — praxisnah, ohne Buzzword-Bingo.
        </p>
      </div>

      <!-- Tags filter -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          <span class="text-xs text-gray-500 font-medium self-center mr-2">Themen:</span>
          {allTags.map(tag => (
            <span class="px-3 py-1.5 text-xs font-medium bg-white/5 text-gray-400 border border-white/10 rounded-full hover:border-brand-500/40 hover:text-brand-300 cursor-default transition-colors">
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Posts grid -->
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-gray-500 text-lg">Noch keine Artikel veröffentlicht.</p>
          <p class="text-gray-600 text-sm mt-2">Schau bald wieder vorbei.</p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => {
            const formattedDate = new Intl.DateTimeFormat('de-DE', { year: 'numeric', month: 'long', day: 'numeric' }).format(post.data.date);
            return (
              <a href={`/blog/${post.slug}`} class="group block bg-white/3 hover:bg-white/5 border border-white/8 hover:border-white/15 rounded-2xl p-7 transition-all duration-300 flex flex-col">
                <div class="flex flex-wrap gap-2 mb-4">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="px-2 py-0.5 text-xs text-brand-400 bg-brand-500/10 rounded-md">{tag}</span>
                  ))}
                </div>
                <h2 class="font-bold text-white mb-2 leading-snug text-lg group-hover:text-brand-300 transition-colors">{post.data.title}</h2>
                <p class="text-gray-400 text-sm line-clamp-3 mb-5 leading-relaxed flex-1">{post.data.description}</p>
                <div class="flex items-center justify-between mt-auto pt-4 border-t border-white/5">
                  <span class="text-xs text-gray-600 font-mono">{formattedDate}</span>
                  <svg class="w-4 h-4 text-gray-600 group-hover:text-brand-400 transition-all group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </main>

  <Footer />
</Layout>
