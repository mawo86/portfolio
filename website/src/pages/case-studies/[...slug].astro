---
import { getCollection } from 'astro:content';
import CaseStudyLayout from '../../layouts/CaseStudyLayout.astro';

export async function getStaticPaths() {
  const studies = await getCollection('case-studies', ({ data }) => !data.draft);
  return studies.map((s) => ({
    params: { slug: s.slug },
    props: { study: s },
  }));
}

const { study } = Astro.props;
const { Content } = await study.render();
const { title, description, client, industry, timeframe, role, services, results } = study.data;
---

<CaseStudyLayout
  title={title}
  description={description}
  client={client}
  industry={industry}
  timeframe={timeframe}
  role={role}
  services={services}
  results={results}
>
  <Content />
</CaseStudyLayout>
