---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('case-studies', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout
  title="Case Studies — Busche Cloud"
  description="Echte Projekte, echte Ergebnisse. Wie ich Unternehmen mit KI-Automatisierung und digitaler Transformation messbar voranbringe."
>
  <Header />
  <main id="main" class="pt-28 pb-24">
    <div class="max-w-5xl mx-auto px-6">

      <div class="border-t-2 border-white/20 pt-10 mb-12">
        <p class="text-brand-400 text-xs font-bold uppercase tracking-[0.2em] mb-5">Case Studies</p>
        <h1 class="text-4xl sm:text-5xl font-black text-white leading-tight tracking-tight mb-5">
          Echte Projekte, messbare Ergebnisse
        </h1>
        <p class="text-gray-400 text-lg leading-relaxed max-w-2xl">
          Keine Hochglanzfolien. Konkrete Use Cases, Vorgehen und Zahlen. Ein Teil meiner Arbeit ist NDA-gebunden — die hier gezeigten Studien sind freigegeben oder anonymisiert.
        </p>
      </div>

      {studies.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-gray-400 text-lg mb-6">Die ersten Case Studies sind in Vorbereitung.</p>
          <a href="/#kontakt" class="inline-flex items-center gap-2 px-5 py-2.5 bg-brand-500 hover:bg-brand-400 text-white font-semibold rounded-lg transition-colors text-sm">
            Gespräch vereinbaren
          </a>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 gap-6">
          {studies.map(s => (
            <a href={`/case-studies/${s.slug}`} class="group block bg-white/3 hover:bg-white/5 border border-white/8 hover:border-brand-500/30 rounded-2xl p-7 transition-all duration-300">
              <div class="flex items-center gap-2 mb-4 text-xs text-gray-500 uppercase tracking-wider">
                <span>{s.data.industry}</span>
                <span class="w-1 h-1 rounded-full bg-gray-700" aria-hidden="true"></span>
                <span>{s.data.timeframe}</span>
              </div>
              <h2 class="text-xl font-bold text-white mb-3 leading-snug group-hover:text-brand-300 transition-colors">{s.data.title}</h2>
              <p class="text-gray-400 text-sm leading-relaxed mb-5">{s.data.description}</p>
              {s.data.results.length > 0 && (
                <div class="flex flex-wrap gap-2 pt-4 border-t border-white/10">
                  {s.data.results.slice(0, 3).map(r => (
                    <span class="px-2.5 py-1 text-xs bg-brand-500/10 text-brand-300 border border-brand-500/20 rounded-md font-semibold">
                      {r.metric} {r.label}
                    </span>
                  ))}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
