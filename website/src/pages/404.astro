---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="404 — Seite nicht gefunden — Busche Cloud"
  description="Die gesuchte Seite existiert nicht oder wurde verschoben."
>
  <Header />
  <main id="main" class="min-h-screen flex items-center justify-center px-6 pt-28 pb-24">
    <div class="max-w-xl mx-auto text-center">
      <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-6">Fehler 404</p>
      <h1 class="text-6xl sm:text-7xl font-black text-white mb-6 leading-none tracking-tight">
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 to-blue-400">Seite weg.</span>
      </h1>
      <p class="text-gray-400 text-lg leading-relaxed mb-10">
        Die Seite, die du suchst, existiert nicht oder wurde verschoben. Vielleicht findest du, was du brauchst, an einer dieser Stellen.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/" class="px-6 py-3 bg-brand-500 hover:bg-brand-400 text-white font-semibold rounded-xl transition-all hover:scale-105 text-sm">
          Zur Startseite
        </a>
        <a href="/blog" class="px-6 py-3 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-xl border border-white/10 hover:border-white/20 transition-all text-sm">
          Blog ansehen
        </a>
        <a href="/tools" class="px-6 py-3 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-xl border border-white/10 hover:border-white/20 transition-all text-sm">
          Tools entdecken
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
