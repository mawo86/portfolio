---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const services = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v3M21 13v4a2 2 0 01-2 2h-3" /></svg>`,
    title: 'KI-Automatisierung & Prompting',
    description: 'Ich schaue mir konkrete Abläufe in deinem Unternehmen an und setze gezielte Automatisierungen um. Vom einfachen Prompt bis zur Integration in bestehende Systeme.',
    tags: ['Prozessautomatisierung', 'Prompt Engineering', 'LLM-Integration'],
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
    title: 'KI-Beratung & KI-Audit',
    description: 'Wo steht dein Unternehmen beim Thema KI? Und wo sind die größten Hebel? Ich helfe dir, Klarheit zu gewinnen und die nächsten Schritte sinnvoll zu priorisieren.',
    tags: ['KI-Strategie', 'KI-Audit', 'Use-Case-Analyse'],
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>`,
    title: 'Digitale Transformation',
    description: 'Über zehn Jahre als IT-Organisator, Inhouse Consultant und Head of Digital. Dieses Handwerkszeug bringe ich mit, wenn es um Prozessanalyse, IT-Strategie und echten Wandel geht.',
    tags: ['IT-Strategie', 'Prozessanalyse', 'Change Management'],
  },
];

const projects = [
  {
    title: 'ERP-Auswahl & Einführungsbegleitung',
    description: 'Begleitung eines Mittelständlers bei der Auswahl und Einführung eines neuen ERP-Systems. Von der Anforderungsaufnahme über den Anbietervergleich bis zum Go-live.',
    tags: ['ERP', 'Anforderungsanalyse', 'Projektmanagement'],
    status: 'Abgeschlossen',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>`,
  },
  {
    title: 'Prozessanalyse & Visualisierung',
    description: 'Aufnahme und Visualisierung bestehender Unternehmensprozesse als Grundlage für Optimierungen. Mit Workshop-Moderation und konkreten Handlungsempfehlungen.',
    tags: ['Prozessanalyse', 'Visualisierung', 'Beratung'],
    status: 'Abgeschlossen',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2"/></svg>`,
  },
  {
    title: 'IT-Strategie & Digitale Transformation',
    description: 'Entwicklung einer IT-Strategie und Begleitung beim digitalen Wandel. Strukturierung der IT-Organisation, Priorisierung von Maßnahmen und Kommunikation mit Stakeholdern.',
    tags: ['IT-Strategie', 'Digitalisierung', 'Organisation'],
    status: 'Abgeschlossen',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  },
  {
    title: 'KI-Consulting',
    description: 'Beratung zu KI-Einsatzmöglichkeiten im Unternehmenskontext. Geeignete Use Cases identifizieren, verfügbare Tools bewerten und erste Projekte gezielt in die Umsetzung bringen.',
    tags: ['KI-Strategie', 'Use Cases', 'Umsetzung'],
    status: 'Laufend',
    icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v3M21 13v4a2 2 0 01-2 2h-3"/></svg>`,
  },
];
---

<Layout title="Busche Cloud — KI-Automatisierung & Digitale Transformation">
  <Header />

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-brand-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-blue-600/8 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-brand-500/3 rounded-full blur-3xl"></div>
    </div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 50px 50px;"></div>

    <div class="relative max-w-6xl mx-auto px-6 py-32 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-300 text-sm font-medium mb-8 animate-fade-in">
        <span class="w-2 h-2 bg-brand-400 rounded-full animate-pulse"></span>
        Verfügbar für neue Projekte
      </div>

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-black text-white mb-6 leading-[1.05] tracking-tight animate-fade-up" style="animation-delay: 0.1s;">
        KI macht dein
        <br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-300 via-brand-400 to-blue-400">
          Unternehmen schneller.
        </span>
      </h1>

      <!-- Subline -->
      <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-up" style="animation-delay: 0.2s;">
        Ich bin Marlon Busche, Digital- und KI-Experte aus OWL. Ich helfe Unternehmen dabei,
        KI sinnvoll einzusetzen und echte Wettbewerbsvorteile daraus zu machen.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-up" style="animation-delay: 0.3s;">
        <a href="/#kontakt" class="px-7 py-3.5 bg-brand-500 hover:bg-brand-400 text-white font-semibold rounded-xl transition-all hover:scale-105 hover:shadow-lg hover:shadow-brand-500/25 text-base">
          Gespräch vereinbaren
        </a>
        <a href="/#projekte" class="px-7 py-3.5 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-xl border border-white/10 hover:border-white/20 transition-all text-base">
          Projekte ansehen
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-20 grid grid-cols-3 gap-6 max-w-lg mx-auto animate-fade-up" style="animation-delay: 0.4s;">
        {[
          { value: '10+', label: 'Jahre IT & Digital' },
          { value: 'OWL', label: 'Verwurzelt in OWL' },
          { value: 'Remote', label: 'und vor Ort' },
        ].map(stat => (
          <div class="text-center">
            <div class="text-3xl font-black text-white">{stat.value}</div>
            <div class="text-xs text-gray-500 mt-1">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-float">
      <span class="text-xs text-gray-600 uppercase tracking-widest">Scroll</span>
      <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  <!-- About -->
  <section id="ueber-mich" class="py-28 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Text -->
        <div>
          <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-4">Über mich</p>
          <h2 class="text-4xl font-bold text-white mb-6 leading-tight">
            Breite IT-Erfahrung,<br />
            <span class="text-brand-400">klarer KI-Fokus</span>
          </h2>
          <div class="space-y-4 text-gray-400 leading-relaxed">
            <p>
              Ich bin in Ostwestfalen-Lippe verwurzelt und arbeite seit über einem Jahrzehnt in der IT. Als Inhouse Consultant, IT-Organisator und zuletzt als Head of Digital habe ich gelernt, neue Technologien nicht isoliert zu betrachten, sondern dort einzusetzen, wo sie wirklich Sinn ergeben.
            </p>
            <p>
              Seit einigen Jahren fokussiere ich mich gezielt auf KI. Wie können Unternehmen KI praktisch nutzen, effizienter werden und Wettbewerbsvorteile aufbauen? Das ist die Frage, die mich antreibt. Und bei der ich helfe.
            </p>
            <p>
              Abseits der Arbeit bin ich gerne draußen in OWL oder stehe an der Dartscheibe. Die Familie hat immer Vorrang.
            </p>
          </div>
          <div class="flex flex-wrap gap-3 mt-8">
            {['KI & Automatisierung', 'Enterprise Architecture', 'SAP', 'Digitale Transformation', 'OWL'].map(tag => (
              <span class="px-3 py-1.5 text-xs font-medium bg-white/5 text-gray-300 border border-white/10 rounded-lg">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <!-- Visual card -->
        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-br from-brand-500/10 to-blue-600/5 rounded-3xl blur-xl"></div>
          <div class="relative bg-white/3 border border-white/10 rounded-3xl p-8 space-y-6">
            <div class="flex items-center gap-4 pb-6 border-b border-white/10">
              <div class="w-14 h-14 rounded-2xl overflow-hidden bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center text-white font-bold text-xl shadow-lg shadow-brand-500/30 flex-shrink-0">
                <img
                  src={`${import.meta.env.BASE_URL}foto.jpg`}
                  alt="Marlon Busche"
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none'; this.parentElement.querySelector('.avatar-fallback').style.display='flex';"
                />
                <span class="avatar-fallback hidden w-full h-full items-center justify-center">MB</span>
              </div>
              <div>
                <div class="font-bold text-white text-lg">Marlon Busche</div>
                <div class="text-brand-400 text-sm">IT & Digital mit Fokus auf KI</div>
              </div>
            </div>

            {[
              {
                icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
                label: 'Standort', value: 'Ostwestfalen-Lippe',
              },
              {
                icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v3M21 13v4a2 2 0 01-2 2h-3"/></svg>`,
                label: 'Fokus', value: 'KI-Automatisierung',
              },
              {
                icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
                label: 'Erfahrung', value: '10+ Jahre Digital',
              },
              {
                icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>`,
                label: 'Arbeitsweise', value: 'Remote & vor Ort',
              },
            ].map(item => (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-brand-500/10 border border-brand-500/15 flex items-center justify-center text-brand-400 flex-shrink-0" set:html={item.icon}></div>
                <div>
                  <div class="text-xs text-gray-500">{item.label}</div>
                  <div class="text-sm text-white font-medium">{item.value}</div>
                </div>
              </div>
            ))}

            <a
              href="https://linkedin.com/in/marlon-b-26203116a"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center gap-2 w-full py-2.5 bg-[#0A66C2]/10 hover:bg-[#0A66C2]/20 text-[#0A66C2] border border-[#0A66C2]/30 rounded-xl text-sm font-medium transition-colors"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn Profil
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="leistungen" class="py-28 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-4">Leistungen</p>
        <h2 class="text-4xl font-bold text-white mb-4">Was ich für dich tue</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Pragmatisch und umsetzungsorientiert. Mit dem Blick fürs große Ganze.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {services.map((service, i) => (
          <div class="group relative bg-white/3 hover:bg-white/5 border border-white/8 hover:border-brand-500/30 rounded-2xl p-7 transition-all duration-300 overflow-hidden">
            <!-- Ghost number -->
            <div class="absolute top-4 right-5 text-7xl font-black text-white/[0.03] select-none leading-none group-hover:text-brand-500/5 transition-colors">
              {String(i + 1).padStart(2, '0')}
            </div>
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-brand-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="relative">
              <div class="w-12 h-12 rounded-xl bg-brand-500/10 border border-brand-500/20 flex items-center justify-center text-brand-400 mb-5 group-hover:bg-brand-500/20 transition-colors" set:html={service.icon}></div>
              <h3 class="text-lg font-bold text-white mb-3">{service.title}</h3>
              <p class="text-gray-400 text-sm leading-relaxed mb-5">{service.description}</p>
              <div class="flex flex-wrap gap-2">
                {service.tags.map(tag => (
                  <span class="px-2 py-1 text-xs bg-white/5 text-gray-400 rounded-md">{tag}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section id="tools" class="py-28 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-4">Tools & Tech</p>
        <h2 class="text-4xl font-bold text-white mb-4">Womit ich arbeite</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Kein Tool-Bingo. Das sind die Werkzeuge, die ich tatsächlich einsetze.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {[
          {
            category: 'KI & LLMs',
            icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v3M21 13v4a2 2 0 01-2 2h-3" /></svg>`,
            tools: ['ChatGPT / GPT-4', 'Claude', 'Microsoft Copilot', 'Perplexity'],
          },
          {
            category: 'Automatisierung',
            icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>`,
            tools: ['n8n', 'Make (Integromat)', 'Power Automate', 'Zapier'],
          },
          {
            category: 'Enterprise',
            icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
            tools: ['SAP', 'Microsoft 365', 'Azure', 'SharePoint'],
          },
          {
            category: 'Analyse & Strategie',
            icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
            tools: ['Miro', 'Confluence', 'Jira', 'PowerBI'],
          },
        ].map(group => (
          <div class="bg-white/3 border border-white/8 rounded-2xl p-6">
            <div class="flex items-center gap-2.5 mb-5">
              <div class="text-brand-400" set:html={group.icon}></div>
              <span class="text-sm font-semibold text-white">{group.category}</span>
            </div>
            <div class="flex flex-col gap-2">
              {group.tools.map(tool => (
                <span class="px-3 py-1.5 text-xs text-gray-300 bg-white/5 border border-white/8 rounded-lg">
                  {tool}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projekte" class="py-28 border-t border-white/5">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-4">Projekte</p>
        <h2 class="text-4xl font-bold text-white mb-4">Ausgewählte Arbeiten</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Echte Projekte. Echte Ergebnisse. Keine Hochglanzfolien.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {projects.map((project) => (
          <div class="group relative bg-white/3 hover:bg-white/5 border border-white/8 hover:border-white/15 rounded-2xl p-7 transition-all duration-300 flex flex-col">
            <div class="flex items-start justify-between mb-5">
              <span class={`inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-1 rounded-full ${project.status === 'Laufend' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-gray-500/10 text-gray-400 border border-gray-500/20'}`}>
                <span class={`w-1.5 h-1.5 rounded-full ${project.status === 'Laufend' ? 'bg-green-400 animate-pulse' : 'bg-gray-400'}`}></span>
                {project.status}
              </span>
              <div class="w-9 h-9 rounded-xl bg-brand-500/10 border border-brand-500/15 flex items-center justify-center text-brand-400 flex-shrink-0 group-hover:bg-brand-500/20 group-hover:border-brand-500/30 transition-colors" set:html={project.icon}></div>
            </div>

            <h3 class="text-base font-bold text-white mb-3 leading-tight">{project.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-5 flex-1">{project.description}</p>

            <div class="flex flex-wrap gap-2 mt-auto">
              {project.tags.map(tag => (
                <span class="px-2 py-1 text-xs bg-brand-500/8 text-brand-400 border border-brand-500/15 rounded-md">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Own Products -->
