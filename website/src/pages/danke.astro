---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Danke für deine Nachricht — Busche Cloud"
  description="Deine Nachricht ist angekommen. Ich melde mich innerhalb von 24 Stunden."
>
  <Fragment slot="head">
    <meta name="robots" content="noindex,follow" />
  </Fragment>
  <Header />
  <main id="main" class="min-h-screen flex items-center justify-center px-6 pt-28 pb-24">
    <div class="max-w-xl mx-auto text-center">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-brand-500/15 border border-brand-500/30 text-brand-400 mb-8">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <p class="text-brand-400 text-sm font-semibold uppercase tracking-widest mb-5">Nachricht angekommen</p>
      <h1 class="text-4xl sm:text-5xl font-black text-white mb-6 leading-tight tracking-tight">
        Danke für dein Interesse.
      </h1>
      <p class="text-gray-400 text-lg leading-relaxed mb-10">
        Ich habe deine Nachricht erhalten und melde mich innerhalb von 24 Stunden bei dir zurück — meistens schneller. Bis dahin kannst du dir gerne ein paar meiner Gedanken durchlesen.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="/blog" class="px-6 py-3 bg-brand-500 hover:bg-brand-400 text-white font-semibold rounded-xl transition-all hover:scale-105 text-sm">
          Blog lesen
        </a>
        <a href="/" class="px-6 py-3 bg-white/5 hover:bg-white/10 text-white font-semibold rounded-xl border border-white/10 hover:border-white/20 transition-all text-sm">
          Zur Startseite
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
